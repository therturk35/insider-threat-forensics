def toplu_sahtecilik_taramasi(klasor_yolu):
    print(f"--- Tarama Başlatıldı: {klasor_yolu} ---\n")
    print(f"{'Dosya Adı':<25} | {'Durum':<15}")
    print("-" * 45)

    for dosya in os.listdir(klasor_yolu):
        yol = os.path.join(klasor_yolu, dosya)
        if os.path.isfile(yol):
            with open(yol, 'rb') as f:
                header = f.read(8)
                görünen_uzanti = os.path.splitext(dosya)[1].lower()
                
                tespit_edilen = "Bilinmiyor"
                for imza, (gercek_uzanti, isim) in SIGNATURES.items():
                    if header.startswith(imza):
                        if görünen_uzanti != gercek_uzanti:
                            tespit_edilen = f"SAHTE! (Aslında {isim})"
                        else:
                            tespit_edilen = "Güvenli"
                        break
                
                print(f"{dosya[:25]:<25} | {tespit_edilen:<15}")

