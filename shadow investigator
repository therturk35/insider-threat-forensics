def timeline_olustur(hedef_klasor):
    print(f"--- Timeline (Zaman Çizelgesi) Oluşturuluyor: {hedef_klasor} ---")
    
    olaylar_listesi = []

    for kok_dizin, klasorler, dosyalar in os.walk(hedef_klasor):
        for dosya in dosyalar:
            tam_yol = os.path.join(kok_dizin, dosya)
            
            try:
                stat = os.stat(tam_yol)
                olaylar_listesi.append({
                    "zaman": stat.st_ctime,
                    "tarih_str": datetime.datetime.fromtimestamp(stat.st_ctime).strftime('%Y-%m-%d %H:%M:%S'),
                    "tur": "[+] CREATED ",
                    "dosya": dosya
                })
                
       
                olaylar_listesi.append({
                    "zaman": stat.st_mtime,
                    "tarih_str": datetime.datetime.fromtimestamp(stat.st_mtime).strftime('%Y-%m-%d %H:%M:%S'),
                    "tur": "[*] MODIFIED",
                    "dosya": dosya
                })
                
                
            except Exception as e:
                continue

    olaylar_listesi.sort(key=lambda x: x['zaman'])

    print(f"\n{'ZAMAN':<22} | {'OLAY TÜRÜ':<12} | {'DOSYA ADI'}")
    print("-" * 60)

    for olay in olaylar_listesi:
        print(f"{olay['tarih_str']:<22} | {olay['tur']:<12} | {olay['dosya']}")

    with open("timeline_raporu.csv", "w", newline='', encoding='utf-8') as f:
        yazici = csv.writer(f)
        yazici.writerow(["Zaman", "Olay Turu", "Dosya Adi"])
        for olay in olaylar_listesi:
            yazici.writerow([olay['tarih_str'], olay['tur'], olay['dosya']])
            
    print("\n[+] Timeline 'timeline_raporu.csv' olarak da kaydedildi.")


timeline_olustur(".")

