def process_izle(limit=10):
    print(f"--- Canlı Sistem Analizi | {datetime.datetime.now()} ---\n")
    print(f"{'PID':<8} | {'İsim':<25} | {'Durum':<12} | {'Bellek (MB)':<10}")
    print("-" * 65)

    
    for proc in psutil.process_iter(['pid', 'name', 'status', 'memory_info']):
        try:
            info = proc.info
            pid = info['pid']
            name = info['name']
            status = info['status']
            memory = info['memory_info'].rss / (1024 * 1024)

            if memory > 50: 
                print(f"{pid:<8} | {name:<25} | {status:<12} | {memory:>10.2f} MB")
                
                if "temp" in proc.exe().lower():
                    print(f" >> [KRİTİK UYARI] Bu işlem geçici klasörden (Temp) çalışıyor: {proc.exe()}")

        except (psutil.NoSuchProcess, psutil.AccessDenied, psutil.ZombieProcess):
            continue
process_izle()

